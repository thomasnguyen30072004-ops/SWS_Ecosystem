# 2. Hàm Tiền xử lý CLAHE (Giữ nguyên logic nét căng của em)
def preprocess_dataset(path):
    clahe = cv2.createCLAHE(clipLimit=2.0, tileGridSize=(8,8))
    for root, dirs, files in os.walk(path):
        for file in tqdm(files, desc=f"Processing {os.path.basename(root)}"):
            if file.lower().endswith(('.png', '.jpg', '.jpeg')):
                img_path = os.path.join(root, file)
                img = cv2.imread(img_path)
                if img is None: continue
                lab = cv2.cvtColor(img, cv2.COLOR_BGR2LAB)
                l, a, b = cv2.split(lab)
                l_updated = clahe.apply(l)
                updated_lab = cv2.merge((l_updated, a, b))
                final_img = cv2.cvtColor(updated_lab, cv2.COLOR_LAB2BGR)
                cv2.imwrite(img_path, final_img)

# Chỉ chạy nếu tìm thấy đường dẫn
if real_train_path:
    preprocess_dataset(real_train_path)
    preprocess_dataset(real_val_path)
    print("\n✨ Đã tiền xử lý CLAHE xong cho toàn bộ ảnh!")










import os, shutil
from ultralytics import YOLO

# Định vị lại thư mục chứa train và val thực tế
dataset_root = '/content/dataset'
train_path = None
val_path = None

for root, dirs, files in os.walk(dataset_root):
    if 'train' in dirs and 'val' in dirs:
        train_path = os.path.join(root, 'train')
        val_path = os.path.join(root, 'val')
        # Đây chính là thư mục "gốc" chuẩn mà YOLO cần
        data_root_final = root
        break

if train_path:
    print(f"🎯 Đã tìm thấy vị trí chuẩn: {data_root_final}")
    print(f"📂 Các lớp trong train: {os.listdir(train_path)}")

    # --- BẮT ĐẦU HUẤN LUYỆN  ---
    model = YOLO('yolov8n-cls.pt')

    model.train(
        data=data_root_final,    # Sử dụng chính xác thư mục chứa train/val
        epochs=100,
        imgsz=224,
        batch=32,
        device=0,
        project='/content/drive/MyDrive/DO_AN_TOT_NGHIEP',
        name='SWS_4Classes_CLAHE_Fixed',

        # Giữ các tham số tối ưu
        degrees=25.0,
        fliplr=0.5,
        flipud=0.0,
        scale=0.6,
        shear=10.0,
        optimizer='AdamW',
        save=True,
        pretrained=True
    )
else:
    print("❌ Không tìm thấy cấu trúc train/val. Hãy chạy lệnh '!ls -R /content/dataset' để kiểm tra lại file zip.")