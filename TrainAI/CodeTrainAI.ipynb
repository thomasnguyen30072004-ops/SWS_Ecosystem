# --- TÌM ĐƯỜNG DẪN  ---
def find_path(root_dir, target_name):
    for root, dirs, files in os.walk(root_dir):
        if target_name in dirs:
            return os.path.join(root, target_name)
    return None

# Tìm thư mục train và val 
real_train_path = find_path(dataset_root, 'train')
real_val_path = find_path(dataset_root, 'val')

if real_train_path and real_val_path:
    # Lấy thư mục cha của train để làm đường dẫn data cho YOLO
    final_data_path = os.path.dirname(real_train_path)
    print(f"✅ Đã tìm thấy dữ liệu tại: {final_data_path}")
    print(f"📂 Các lớp rác: {os.listdir(real_train_path)}")
else:
